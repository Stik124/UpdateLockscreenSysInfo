<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">

    <Product Id="A7D8F4E2-1C83-4A89-B6C5-9E3F2A1B8C7D"
             Name="UpdateLockScreen"
             Language="1033"
             Version="VERSION_PLACEHOLDER"
             Manufacturer="Avdeev D.V."
             UpgradeCode="A7D8F4E2-1C83-4A89-B6C5-9E3F2A1B8C7D"
             Codepage="1251">

        <Package InstallerVersion="200" Compressed="yes" InstallScope="perMachine" Platform="x64" />

        <!-- ==================== ОБНОВЛЕНИЕ ==================== -->
        <MajorUpgrade
            DowngradeErrorMessage="Новая версия UpdateLockScreen уже установлена. Установка старой версии невозможна."
            Schedule="afterInstallInitialize" />

        <MediaTemplate EmbedCab="yes" />

        <Feature Id="ProductFeature" Title="UpdateLockScreen" Level="1">
            <ComponentRef Id="MainFiles" />
        </Feature>

        <Directory Id="TARGETDIR" Name="SourceDir">
            <Directory Id="ProgramFiles64Folder">
                <Directory Id="INSTALLFOLDER" Name="UpdateLockScreen">
                    <Component Id="MainFiles" Guid="D4E5F6A7-B8C9-4D3E-8F1A-2B3C4D5E6F79" Win64="yes">
                        <File Source="files\install-script.ps1" />
                        <File Source="files\uninstall-script.ps1" />
                        <File Source="files\background.jpg" />
                    </Component>
                </Directory>
            </Directory>
        </Directory>

        <!-- ==================== CUSTOM ACTIONS ==================== -->

        <!-- Остановка процессов перед обновлением/удалением -->
        <CustomAction Id="StopProcesses"
            Directory="INSTALLFOLDER"
            ExeCommand='powershell.exe -NoProfile -ExecutionPolicy Bypass -Command "Stop-ScheduledTask -TaskName UpdateLockScreen -ErrorAction SilentlyContinue; Get-Process wscript,powershell -ErrorAction SilentlyContinue | Where-Object {$_.Path -like ''*UpdateLockScreen*''} | Stop-Process -Force -ErrorAction SilentlyContinue; Start-Sleep -Seconds 2"'
            Execute="immediate"
            Return="ignore"
            Impersonate="no" />

        <CustomAction Id="RunInstallScript"
            Directory="INSTALLFOLDER"
            ExeCommand='powershell.exe -NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -File "install-script.ps1"'
            Execute="deferred"
            Return="check"
            Impersonate="no" />

        <CustomAction Id="RunUninstallScript"
            Directory="INSTALLFOLDER"
            ExeCommand='powershell.exe -NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -File "uninstall-script.ps1"'
            Execute="deferred"
            Return="ignore"
            Impersonate="no" />

        <InstallExecuteSequence>
            <!-- Останавливаем процессы ПЕРЕД началом установки/обновления -->
            <Custom Action="StopProcesses" Before="InstallValidate">
                Installed OR UPGRADINGPRODUCTCODE
            </Custom>

            <!-- При установке и обновлении -->
            <Custom Action="RunInstallScript" After="InstallFiles">
                NOT Installed OR UPGRADINGPRODUCTCODE
            </Custom>

            <!-- При удалении -->
            <Custom Action="RunUninstallScript" Before="RemoveFiles">
                REMOVE="ALL"
            </Custom>
        </InstallExecuteSequence>

    </Product>

</Wix>
